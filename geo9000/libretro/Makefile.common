INCFLAGS := -I$(CORE_DIR)/deps -I$(CORE_DIR)/deps/libretro-common/include \
	-I$(CORE_DIR)/deps/miniz -I$(CORE_DIR)/src -I$(CORE_DIR)/libretro -I../../e9k-lib

## External SDL windows removed; no SDL dependencies needed

ifeq ($(platform),unix)
LIBS += -lm
endif

SOURCES_C := \
	$(CORE_DIR)/libretro/libretro.c \
